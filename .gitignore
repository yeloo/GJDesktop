# ============================================================
# CCDesk - Qt6 + CMake + Windows  .gitignore
# ============================================================

# ------------------------------------------------------------
# CMake 编译产物
# ------------------------------------------------------------
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# ------------------------------------------------------------
# 可执行文件与库
# ------------------------------------------------------------
*.exe
*.dll
*.pdb
*.ilk
*.exp
*.lib
*.a
*.so
*.dylib

# ------------------------------------------------------------
# Visual Studio 编译中间文件
# ------------------------------------------------------------
*.obj
*.pch
*.idb
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.opendb

# Visual Studio 项目文件（CMake 生成，不需要纳入版本控制）
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# Visual Studio 用户配置
.vs/
*.user
*.suo
*.suo

# ------------------------------------------------------------
# Qt 相关
# ------------------------------------------------------------
# Qt Creator 项目缓存
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
*.qmlproject.user
*.qmlproject.user.*

# Qt Creator CMake 缓存
CMakeLists.txt.user
CMakeLists.txt.user.*

# Qt 生成的 moc 文件（CMake AUTOMOC 自动处理）
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp

# Qt 资源编译缓存
*.rcc

# ------------------------------------------------------------
# Windows 系统文件
# ------------------------------------------------------------
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ------------------------------------------------------------
# 运行时生成文件（不应提交）
# ------------------------------------------------------------
logs/
*.log

# 配置文件（含用户路径，不应提交；模板可提交）
config/ccdesk_config.json

# ------------------------------------------------------------
# Python 缓存（src/ 中有 .py 辅助脚本）
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
*.whl

# ------------------------------------------------------------
# 编辑器 / IDE
# ------------------------------------------------------------
# JetBrains (CLion)
.idea/
*.iml
*.iws

# VSCode
.vscode/
*.code-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-workspace

# ------------------------------------------------------------
# 压缩与发布包（不提交到仓库）
# ------------------------------------------------------------
*.zip
*.tar.gz
*.tar.bz2
*.7z
*.rar
release/
release_package/
deploy/
dist/

# ------------------------------------------------------------
# 其他
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.DS_Store
